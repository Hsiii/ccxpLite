{
  "name": "ccxp-lite",
  "private": true,
  "version": "1.7.2",
  "description": "A minimalism theme plugin for NTHU CCXP.",
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.3.9"
  },
  "scripts": {
    "build": "bun run build:crx && bun run build:firefox",
    "build:crx": "bun run scripts/build.ts --target crx",
    "build:firefox": "bun run scripts/build.ts --target firefox",
    "clean": "rm -rf dist .build",
    "capture": "bun run scripts/capture_marketing_images.ts",
    "update:readme-assets": "bun run scripts/update_readme_assets.ts",
    "release": "bun run release:crx && bun run release:firefox",
    "release:crx": "bun run scripts/release.ts --target crx",
    "release:firefox": "bun run scripts/release.ts --target firefox",
    "test": "bunx vitest run",
    "test:unit": "bunx vitest run",
    "test:vitest": "bunx vitest run",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "typecheck": "bunx tsc -b --noEmit tsconfig.json",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,css}": [
      "bunx prettier --write"
    ],
    "*.{ts,tsx,js,mjs,cjs}": [
      "bunx eslint --fix"
    ]
  },
  "devDependencies": {
    "@types/chrome": "^0.1.24",
    "@types/node": "^24.9.1",
    "bun-types": "^1.3.9",
    "complete-lint": "^5.1.5",
    "eslint": "^9.25.1",
    "eslint-config-complete": "^4.1.4",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "playwright": "^1.59.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
