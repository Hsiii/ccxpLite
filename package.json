{
  "name": "ccxp-lite",
  "private": true,
  "version": "1.3.0",
  "description": "A minimalism theme plugin for NTHU CCXP.",
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.3.9"
  },
  "scripts": {
    "build": "bun run scripts/build.mjs",
    "test": "bun test",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,json,md,css}": [
      "bunx prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "bunx eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "bun-types": "^1.3.9",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
