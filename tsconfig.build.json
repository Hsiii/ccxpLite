{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["chrome"],
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./.build/src"
  },
  "include": ["src/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["dist", "node_modules", ".playwright-cli", "fixtures/ccxp-snapshot"]
}
